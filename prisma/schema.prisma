generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth (NextAuth v5 Prisma adapter) ───────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Domain ──────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?

  username          String?   @unique
  bio               String?   @db.Text
  twitterHandle String?
  githubHandle  String?
  website       String?
  walletAddress     String?   @unique
  submissionCredits     Int       @default(2)
  reputationScore       Int       @default(0)
  lastSeenAt            DateTime?
  lastBuildUpdateCredit DateTime?
  lastCommentCredit     DateTime?
  isAdmin               Boolean   @default(false)
  isBanned              Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  projects    Project[]
  updates     ProjectUpdate[]
  comments    Comment[]
  upvotes     Upvote[]
  downvotes   Downvote[]
  discussions     Discussion[]
  replies         Reply[]
  projectReviews  ProjectReview[]
  following       Follow[]       @relation("Follower")
  followers       Follow[]       @relation("Following")
  notifications   Notification[]

  hostedSessions    BuilderSession[]   @relation("BuilderSessionHost")
  hostedSpaces      Space[]            @relation("SpaceHost")
  spaceParticipants SpaceParticipant[]
  reports           Report[]
}

enum ProjectStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  ARCHIVED
  EXPIRED
}

model Project {
  id            String        @id @default(cuid())
  slug          String        @unique
  title         String
  tagline       String
  description   String        @db.Text
  genlayerAngle String        @db.Text
  contractAddress String?
  verified       Boolean       @default(false)
  upvoteCreditsAwarded Int     @default(0)
  featured             Boolean @default(false)
  repoUrl        String?
  demoUrl        String?
  coverImage     String?
  status         ProjectStatus @default(DRAFT)
  publishedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  remixedFromId  String?
  remixedFrom    Project?  @relation("ProjectRemix", fields: [remixedFromId], references: [id], onDelete: SetNull)
  remixes        Project[] @relation("ProjectRemix")

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  tags     ProjectTag[]
  updates  ProjectUpdate[]
  comments Comment[]
  upvotes   Upvote[]
  downvotes Downvote[]
  reviews   ProjectReview[]
  sessions BuilderSession[]
  spaces   Space[]
}

model Tag {
  id       String       @id @default(cuid())
  name     String       @unique
  slug     String       @unique
  projects ProjectTag[]
  sessions BuilderSession[]
  spaces   Space[]
}

model ProjectTag {
  projectId String
  tagId     String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([projectId, tagId])
}

enum UpdateType {
  GENERAL
  MILESTONE
  BLOCKER
  BREAKTHROUGH
}

model ProjectUpdate {
  id        String     @id @default(cuid())
  type      UpdateType @default(GENERAL)
  content   String     @db.Text
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  comments Comment[]
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  updateId String?
  update   ProjectUpdate? @relation(fields: [updateId], references: [id], onDelete: Cascade)
}

model Follow {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())

  followerId  String
  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)

  followingId String
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

enum NotificationType {
  FOLLOW
  PROJECT_REVIEW
  PROJECT_PUBLISHED
  PROJECT_REJECTED
  PROJECT_EXPIRED
  NEW_UPDATE
  NEW_PROJECT
  COMMENT
  DISCUSSION_REPLY
  SPACE_LIVE
  UPVOTE_MILESTONE
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  message   String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ReviewDecision {
  APPROVED
  REJECTED
}

model ProjectReview {
  id        String         @id @default(cuid())
  decision  ReviewDecision
  feedback  String?        @db.Text
  createdAt DateTime       @default(now())

  projectId  String
  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  reviewerId String
  reviewer   User   @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  @@unique([reviewerId, projectId])
}

model Upvote {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

model Downvote {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

enum DiscussionCategory {
  GENERAL
  HELP
  IDEAS
  SHOWCASE
}

model Discussion {
  id        String             @id @default(cuid())
  title     String
  content   String             @db.Text
  category  DiscussionCategory @default(GENERAL)
  pinned    Boolean            @default(false)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  replies Reply[]
}

model Reply {
  id        String   @id @default(cuid())
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  discussionId String
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
}

// ─── Builder Sessions (YouTube-embedded) ─────────────────────────────────────

enum BuilderSessionStatus {
  SCHEDULED
  LIVE
  ENDED
}

model BuilderSession {
  id             String               @id @default(cuid())
  title          String
  description    String?              @db.Text
  status         BuilderSessionStatus @default(SCHEDULED)
  scheduledAt    DateTime?
  startedAt      DateTime?
  endedAt        DateTime?
  youtubeUrl     String?
  youtubeVideoId String?
  isRecurring    Boolean              @default(false)
  recurrence     String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  hostId  String
  host    User     @relation("BuilderSessionHost", fields: [hostId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  tags Tag[]
}

// ─── Spaces (Live audio rooms via Livekit) ───────────────────────────────────

enum SpaceStatus {
  SCHEDULED
  LIVE
  ENDED
}

enum ParticipantRole {
  HOST
  SPEAKER
  LISTENER
}

model Space {
  id            String      @id @default(cuid())
  title         String
  description   String?     @db.Text
  status        SpaceStatus @default(SCHEDULED)
  scheduledAt   DateTime?
  startedAt     DateTime?
  endedAt       DateTime?
  roomName      String      @unique
  listenerCount Int         @default(0)
  replayUrl     String?
  xSpaceUrl     String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  hostId  String
  host    User     @relation("SpaceHost", fields: [hostId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  participants SpaceParticipant[]
  tags         Tag[]
}

model SpaceParticipant {
  id         String          @id @default(cuid())
  role       ParticipantRole @default(LISTENER)
  handRaised Boolean         @default(false)
  joinedAt   DateTime        @default(now())

  spaceId String
  space   Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([spaceId, userId])
}

model Report {
  id         String   @id @default(cuid())
  type       String
  contentId  String
  reason     String?  @db.Text
  resolved   Boolean  @default(false)
  createdAt  DateTime @default(now())

  reporterId String
  reporter   User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([reporterId, type, contentId])
}
